@startuml
start

:Initialize Tables & Files;

while (More Addresses?) is (yes)
    :Get Logical Address;
    :Check TLB & Page Table;
    
    if (Not in Memory?) then (Page Fault)
        :Load Page from Disk to RAM;
    endif
    
    :Convert to Physical Address;
    :Print Result;
endwhile (no)

:Print Stats & Close;
stop
@enduml